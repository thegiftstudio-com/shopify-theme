<script>
(function () {
  if (window.__expressSelectorBound) return;
  window.__expressSelectorBound = true;

  function pad2(n) { return String(n).padStart(2, '0'); }
  function parseDMYLocal(str) {
    if (!str) return null;
    var p = String(str).split('-');
    if (p.length < 3) return null;
    var d = parseInt(p[0], 10), m = parseInt(p[1], 10), y = parseInt(p[2], 10);
    if (y < 100) y += 2000;
    if (!d || !m || !y) return null;
    return new Date(y, m - 1, d);
  }
  function fmtDMYLocal(d) { return pad2(d.getDate()) + '-' + pad2(d.getMonth() + 1) + '-' + d.getFullYear(); }
  function fmtPromiseLocal(d) {
    var today = new Date(); today.setHours(0, 0, 0, 0);
    var x = new Date(d); x.setHours(0, 0, 0, 0);
    var diff = Math.round((x - today) / 86400000);
    if (diff <= 0) return 'today';
    if (diff === 1) return 'tomorrow';
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    return x.getDate() + ' ' + months[x.getMonth()];
  }

  // Standard = earliest + 2 days, then respect the existing Sunday-skip rule.
  function computeStandardDate(earliest) {
    var d = new Date(earliest.getFullYear(), earliest.getMonth(), earliest.getDate());
    d.setDate(d.getDate() + 2);
    var noSunday = (typeof enableSundayDelivery !== 'undefined') && !enableSundayDelivery;
    if (noSunday) {
      var temp = new Date(earliest.getFullYear(), earliest.getMonth(), earliest.getDate());
      var sundays = 0;
      temp.setDate(temp.getDate() + 1);
      while (temp <= d) { if (temp.getDay() === 0) sundays++; temp.setDate(temp.getDate() + 1); }
      d.setDate(d.getDate() + sundays);
      while (d.getDay() === 0) d.setDate(d.getDate() + 1);
    }
    return d;
  }

  function updateExpressChargeText() {
    var paise = (window.EXPRESS_CHARGE && window.EXPRESS_CHARGE.price_paise) || 0;
    var rupees = paise / 100;
    var $fee = $('.express-charge-text');
    // Hide the fee pill when express is unavailable or there is no fee yet.
    if (paise > 0 && $('#express_eligible_flag').val() === '1') {
      $fee.text('+ ₹' + (Number.isInteger(rupees) ? rupees : rupees.toFixed(2))).css('display', '');
    } else {
      $fee.text('').css('display', 'none');
    }
  }

  function applyMode(mode) {
    var $picker = $('#delivery-date-5');
    $('#delivery_mode_selected').val(mode);
    var dateStr = (mode === 'express') ? $('#express_selected_date').val() : $('#standard_selected_date').val();
    var d = parseDMYLocal(dateStr);
    if (d) { $picker.datepicker('setDate', d); }
    $picker.trigger('change');
    // Premium card highlight
    $('.tgs-delivery-card').removeClass('is-selected');
    $((mode === 'express') ? '.express-option' : '.standard-option').addClass('is-selected');
  }

  // Called from the pincode-AJAX success handler, right after setMinDeliveryDate().
  window.setupExpressStandardSelector = function (totalTat) {
    var earliest = parseDMYLocal($('#delivery-date-5').val());
    if (!earliest) return;

    var isEligible = parseInt(totalTat, 10) <= 2; // T, T+1, T+2 only
    var standard = computeStandardDate(earliest);

    $('.express-date-text').text('by ' + fmtPromiseLocal(earliest));
    $('.standard-date-text').text('by ' + fmtPromiseLocal(standard));
    updateExpressChargeText();
    // The live price may still be hydrating from GraphQL; refresh the fee text once it resolves.
    if (window.expressChargeReady && window.expressChargeReady.then) {
      window.expressChargeReady.then(updateExpressChargeText);
    }

    $('#express_selected_date').val(fmtDMYLocal(earliest));
    $('#standard_selected_date').val(fmtDMYLocal(standard));
    $('#express_eligible_flag').val(isEligible ? '1' : '0');

    var $express = $('.express-radio');
    if (isEligible) {
      $express.prop('disabled', false);
      $('.express-option').removeClass('disabled');
      $('.express-date-text').show();
      $('.express-unavailable-note').hide();
      $express.prop('checked', true);
      applyMode('express');
    } else {
      $express.prop('disabled', true).prop('checked', false);
      $('.express-option').addClass('disabled');
      $('.express-date-text').hide();
      $('.express-unavailable-note').show();
      $('.standard-radio').prop('checked', true);
      applyMode('standard');
    }
    updateExpressChargeText(); // re-evaluate fee pill visibility now that eligibility is set
    $('.express-standard-selector').show();
  };

  $(document).on('change', 'input[name="delivery_mode"]', function () {
    if ($(this).is(':disabled')) return;
    applyMode($(this).val());
  });

  if (window.expressChargeReady && window.expressChargeReady.then) {
    window.expressChargeReady.then(updateExpressChargeText);
  }
})();
</script>

