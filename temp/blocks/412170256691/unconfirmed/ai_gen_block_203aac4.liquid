{% doc %}
  @prompt
    An interactive vertical timeline that highlights as the user scrolls
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-timeline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-timeline-container-{{ ai_gen_id }} {
    position: relative;
    max-width: 900px;
    margin: 0 auto;
  }

  .ai-timeline-line-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 3px;
    background-color: {{ block.settings.line_color }};
    transform: translateX(-50%);
    z-index: 1;
  }

  .ai-timeline-progress-{{ ai_gen_id }} {
    position: absolute;
    left: 0;
    top: 0;
    width: 100%;
    height: 0%;
    background-color: {{ block.settings.active_line_color }};
    transition: height 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }} {
    position: relative;
    margin-bottom: 80px;
    opacity: 0.4;
    transition: opacity 0.5s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-timeline-item-{{ ai_gen_id }}:last-child {
    margin-bottom: 0;
  }

  .ai-timeline-content-{{ ai_gen_id }} {
    position: relative;
    width: calc(50% - 40px);
    padding: 24px;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    z-index: 2;
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(odd) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: 0;
    margin-right: auto;
  }

  .ai-timeline-item-{{ ai_gen_id }}:nth-child(even) .ai-timeline-content-{{ ai_gen_id }} {
    margin-left: auto;
    margin-right: 0;
  }

  .ai-timeline-marker-{{ ai_gen_id }} {
    position: absolute;
    left: 50%;
    top: 30px;
    width: {{ block.settings.marker_size }}px;
    height: {{ block.settings.marker_size }}px;
    background-color: {{ block.settings.marker_color }};
    border: 4px solid {{ block.settings.background_color }};
    border-radius: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    transition: all 0.3s ease;
  }

  .ai-timeline-item-{{ ai_gen_id }}.active .ai-timeline-marker-{{ ai_gen_id }} {
    background-color: {{ block.settings.active_marker_color }};
    transform: translate(-50%, -50%) scale(1.2);
    box-shadow: 0 0 0 8px {{ block.settings.active_marker_color }}33;
  }

  .ai-timeline-date-{{ ai_gen_id }} {
    font-size: {{ block.settings.date_font_size }}px;
    color: {{ block.settings.date_color }};
    font-weight: 600;
    margin-bottom: 8px;
  }

  .ai-timeline-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    font-weight: 700;
    margin: 0 0 12px 0;
  }

  .ai-timeline-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-timeline-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 16px;
  }

  .ai-timeline-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-timeline-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 768px) {
    .ai-timeline-line-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-content-{{ ai_gen_id }} {
      width: calc(100% - 60px);
      margin-left: 60px !important;
      margin-right: 0 !important;
    }

    .ai-timeline-marker-{{ ai_gen_id }} {
      left: 20px;
    }

    .ai-timeline-item-{{ ai_gen_id }} {
      margin-bottom: 60px;
    }
  }
{% endstyle %}

<vertical-timeline-{{ ai_gen_id }} class="ai-timeline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-timeline-container-{{ ai_gen_id }}">
    <div class="ai-timeline-line-{{ ai_gen_id }}">
      <div class="ai-timeline-progress-{{ ai_gen_id }}"></div>
    </div>

    {% for i in (1..6) %}
      {% liquid
        assign date_key = 'item_' | append: i | append: '_date'
        assign title_key = 'item_' | append: i | append: '_title'
        assign description_key = 'item_' | append: i | append: '_description'
        assign image_key = 'item_' | append: i | append: '_image'
        assign enabled_key = 'item_' | append: i | append: '_enabled'

        assign item_date = block.settings[date_key]
        assign item_title = block.settings[title_key]
        assign item_description = block.settings[description_key]
        assign item_image = block.settings[image_key]
        assign item_enabled = block.settings[enabled_key]
      %}

      {% if item_enabled %}
        <div class="ai-timeline-item-{{ ai_gen_id }}" data-timeline-item>
          <div class="ai-timeline-marker-{{ ai_gen_id }}"></div>
          <div class="ai-timeline-content-{{ ai_gen_id }}">
            {% if item_image %}
              <img
                src="{{ item_image | image_url: width: 800 }}"
                alt="{{ item_image.alt | escape }}"
                loading="lazy"
                width="{{ item_image.width }}"
                height="{{ item_image.height }}"
                class="ai-timeline-image-{{ ai_gen_id }}"
              >
            {% elsif block.settings.show_image_placeholders %}
              <div class="ai-timeline-image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if item_date != blank %}
              <div class="ai-timeline-date-{{ ai_gen_id }}">{{ item_date }}</div>
            {% endif %}

            {% if item_title != blank %}
              <h3 class="ai-timeline-title-{{ ai_gen_id }}">{{ item_title }}</h3>
            {% endif %}

            {% if item_description != blank %}
              <div class="ai-timeline-description-{{ ai_gen_id }}">{{ item_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</vertical-timeline-{{ ai_gen_id }}>

<script>
  (function() {
    class VerticalTimeline{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.items = [];
        this.progressBar = null;
        this.timelineLine = null;
      }

      connectedCallback() {
        this.items = Array.from(this.querySelectorAll('[data-timeline-item]'));
        this.progressBar = this.querySelector('.ai-timeline-progress-{{ ai_gen_id }}');
        this.timelineLine = this.querySelector('.ai-timeline-line-{{ ai_gen_id }}');
        
        if (this.items.length > 0) {
          this.setupScrollObserver();
          this.updateTimeline();
        }
      }

      setupScrollObserver() {
        const options = {
          root: null,
          rootMargin: '-50% 0px -50% 0px',
          threshold: 0
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
            } else {
              entry.target.classList.remove('active');
            }
          });
          this.updateProgressBar();
        }, options);

        this.items.forEach((item) => {
          observer.observe(item);
        });

        window.addEventListener('scroll', () => {
          this.updateProgressBar();
        });

        window.addEventListener('resize', () => {
          this.updateProgressBar();
        });
      }

      updateProgressBar() {
        if (!this.timelineLine || this.items.length === 0) return;

        const timelineRect = this.timelineLine.getBoundingClientRect();
        const timelineTop = timelineRect.top + window.scrollY;
        const timelineHeight = timelineRect.height;
        const viewportMiddle = window.scrollY + window.innerHeight / 2;

        let progress = 0;

        if (viewportMiddle > timelineTop) {
          progress = ((viewportMiddle - timelineTop) / timelineHeight) * 100;
          progress = Math.min(Math.max(progress, 0), 100);
        }

        if (this.progressBar) {
          this.progressBar.style.height = progress + '%';
        }
      }

      updateTimeline() {
        this.updateProgressBar();
      }
    }

    customElements.define('vertical-timeline-{{ ai_gen_id }}', VerticalTimeline{{ ai_gen_id }});
  })();
</script>

